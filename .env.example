# ==========================================================
# iCloud HME 管理器 - 环境变量配置
# ==========================================================
# 复制本文件为 .env 并按需修改。
# Docker 部署时通过 docker-compose.yml / -e 注入，无需手动创建 .env。

# ---- WebUI 访问密码 ----
# 保护管理面板。留空 = 不启用访问密码。
# 安全策略：留空时，生产环境（NODE_ENV=production）默认禁用管理接口，
# 需显式设置 ALLOW_NO_AUTH=true 才放行（仅建议信任内网）。开发环境留空直接放行。
ACCESS_PASSWORD=

# ---- 管理员用户名（可选）----
# 设置后，登录需「用户名 + 密码」双校验；留空则仅校验密码（向后兼容）。
ADMIN_USERNAME=

# ---- 开放访问逃生口（可选）----
# 仅在未设 ACCESS_PASSWORD 且确实想在生产/公网开放管理接口时设为 true。
# 风险自负：任何人都能管理你的全部别名。
ALLOW_NO_AUTH=

# ---- Cookie 加密密钥 ----
# 32 字节十六进制字符串（64 个 hex 字符），用于 AES-256-GCM 加密账号 Cookie。
# 生成命令：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 留空时，首次启动会自动生成并写入本地 .env（Docker 容器则每次重启都重新生成，导致已存账号失效——务必显式设置）。
ENCRYPTION_KEY=

# ---- 会话签名密钥 ----
# 任意长度随机字符串，用于 iron-session 签名加密会话 cookie。
# 生成命令：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 留空时本地自动生成；Docker 同上务必显式设置。
SESSION_SECRET=

# ---- 数据库与数据目录 ----
# SQLite 文件存放路径。Docker 中对应挂载卷。
DATA_DIR=./data

# ---- 日志级别 ----
# debug / info / warn / error，默认 info。
# 排查问题时设为 debug；生产建议 info 或 warn。
# 日志会同时输出到容器 stdout/stderr（docker logs）和应用内「应用日志」面板。
# 所有敏感值（Cookie / 密码 / token）写入前已脱敏。
LOG_LEVEL=info
